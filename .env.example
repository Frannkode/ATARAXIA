# Base de datos (Neon) — ver Context/Preguntas-Cliente.md
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# Cloudinary (imágenes de producto)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# MercadoPago — se usa a partir del Sprint 3, pero la cuenta de test
# se necesita desde el spike de la Historia 1.7
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
# Secret signature de "Tus Integraciones" en MercadoPago (NO es el Access
# Token) — se usa para validar el header x-signature del webhook (Historia 3.2)
MERCADOPAGO_WEBHOOK_SECRET=""

# Protege GET /api/cron/expire-orders (Historia 3.3) contra llamadas de
# cualquiera — el cron externo (cron-job.org) manda esto como Bearer token
CRON_SECRET=""

# URL pública del sitio (back_urls/notification_url de MercadoPago, links en
# emails). En Vercel se puede omitir y cae a https://$VERCEL_URL automático.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Resend (emails transaccionales) — se usa a partir del Sprint 3
RESEND_API_KEY=""

# Better Auth (panel admin) — se usa a partir del Sprint 4
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
